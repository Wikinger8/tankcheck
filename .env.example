# TankCheck Environment Configuration
# Copy this file to .env and fill in your values

# Tankerkoenig API Key
# Register at https://creativecommons.tankerkoenig.de for your personal key
TANKERKOENIG_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Backend
BACKEND_PORT=3001
NODE_ENV=development

# Redis
REDIS_URL=redis://localhost:6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
